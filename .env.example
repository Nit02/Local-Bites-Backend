# ─── Copy this file to .env and fill in your values ───────────────────────
# NEVER commit the real .env file to git

# Database
DB_URL=jdbc:mysql://localhost:3306/localbites?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

# JWT — use a long random string (min 32 chars)
JWT_SECRET=YourSuperSecretKeyThatIsAtLeast32CharactersLong
JWT_EXPIRATION_MS=86400000

# Server port (optional, defaults to 8080)
PORT=8080
